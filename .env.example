# Copy this file to .env.local and fill in real values
# Never commit .env.local to git

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── OpenAI ───────────────────────────────────────────────────
# Found in: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ── Razorpay ─────────────────────────────────────────────────
# Found in: https://dashboard.razorpay.com/app/keys
# Use rzp_test_... keys for development, rzp_live_... for production
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-razorpay-secret
# Set in Razorpay Dashboard → Webhooks → Create Webhook → copy the Secret shown
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ── Sentry ───────────────────────────────────────────────────
# Found in: https://sentry.io → Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id
# Found in: https://sentry.io → Account → API → Auth Tokens
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=ask-my-notes

# ── App Config ───────────────────────────────────────────────
NEXT_PUBLIC_VERCEL_ENV=development
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public URL used in events/embed route
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Admin email(s) for protected admin routes — comma-separated
ADMIN_EMAILS=shaizan2006@gmail.com
# Used by admin page for client-side admin check
NEXT_PUBLIC_ADMIN_EMAIL=shaizan2006@gmail.com
# RAG similarity threshold (0.0–1.0, default 0.75)
RAG_CONFIDENCE_THRESHOLD=0.75

# ── Cron Secret ──────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Must match the Authorization header sent by Vercel Cron
CRON_SECRET=your-random-cron-secret-here

# ── Web Push (VAPID) ─────────────────────────────────────────
# Generate once: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(JSON.stringify(k))"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:hello@askmynotes.in

# ── AI Spend Circuit Breaker ─────────────────────────────────
# Monthly hard caps per plan in USD. Defaults shown below.
# Raise or lower these in Vercel without a code deploy.
AI_BUDGET_FREE_USD=0.50
AI_BUDGET_STUDENT_USD=3.00
AI_BUDGET_PRO_USD=6.00

# ── Pricing A/B Test ──────────────────────────────────────────
# Set to activate the Pro pricing experiment (₹199 / ₹399 / ₹499).
# Users are deterministically assigned to one of 3 arms on their first pricing page visit.
# Results visible at /admin/metrics under "Pricing A/B Test".
# Unset (or blank) to disable — all users see the control price (₹399).
# AB_TEST_PRICING_EPOCH=pro-price-2026-05

# ── Voice Pro+ Feature Flag ───────────────────────────────────
# Set both to "true" to launch the Pro+ voice tier (₹699/mo, unlimited calls).
# When enabled: Pro plan drops to 3 calls/day; Pro+ gets unlimited.
# When disabled (default): Pro keeps 15 calls/day; Pro+ card hidden on pricing page.
# VOICE_PROPLUS_ENABLED=true
# NEXT_PUBLIC_VOICE_PROPLUS_ENABLED=true

# ── Feature Kill Switches ─────────────────────────────────────
# Set to "0" to disable a feature in prod without touching unrelated code.
# Default (unset or any other value) = enabled.
NEXT_PUBLIC_FEATURE_SUPPORT=1
NEXT_PUBLIC_FEATURE_INCOGNITO=1
NEXT_PUBLIC_FEATURE_DOUBT_SIDEBAR=1

# ── WhatsApp Business API ─────────────────────────────────────
# Provider: AiSensy (recommended) — https://www.aisensy.com
# Alternatives: Gupshup (https://www.gupshup.io) or Interakt (https://www.interakt.shop)
# Cost: ~₹2-5K/mo setup + ~₹0.50-1 per message within India
WHATSAPP_PROVIDER=aisensy
# API key from your provider dashboard
WHATSAPP_API_KEY=your-whatsapp-api-key
# Phone number ID (differs from the display number shown to users)
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WhatsApp Business Account ID from Meta Business Manager
WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id
# Random token for verifying Meta webhook handshake
# Generate: openssl rand -base64 32
WHATSAPP_VERIFY_TOKEN=your-whatsapp-webhook-verify-token
# App secret for verifying incoming webhook HMAC signatures (X-Hub-Signature-256)
# For AiSensy/Meta: copy from Meta App Dashboard → App Secret
# For Gupshup/Interakt: use the shared webhook secret from their dashboard
# REQUIRED in production — webhooks are rejected without this
WHATSAPP_APP_SECRET=your-whatsapp-app-secret
