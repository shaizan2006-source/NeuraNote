# Copy this file to .env.local and fill in real values
# Never commit .env.local to git

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── OpenAI ───────────────────────────────────────────────────
# Found in: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ── Razorpay ─────────────────────────────────────────────────
# Found in: https://dashboard.razorpay.com/app/keys
# Use rzp_test_... keys for development, rzp_live_... for production
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-razorpay-secret
# Set in Razorpay Dashboard → Webhooks → Create Webhook → copy the Secret shown
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ── Sentry ───────────────────────────────────────────────────
# Found in: https://sentry.io → Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id
# Found in: https://sentry.io → Account → API → Auth Tokens
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=ask-my-notes

# ── App Config ───────────────────────────────────────────────
NEXT_PUBLIC_VERCEL_ENV=development
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public URL used in events/embed route
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Admin email(s) for protected admin routes — comma-separated
ADMIN_EMAILS=shaizan2006@gmail.com
# Used by admin page for client-side admin check
NEXT_PUBLIC_ADMIN_EMAIL=shaizan2006@gmail.com
# RAG similarity threshold (0.0–1.0, default 0.75)
RAG_CONFIDENCE_THRESHOLD=0.75

# ── Cron Secret ──────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Must match the Authorization header sent by Vercel Cron
CRON_SECRET=your-random-cron-secret-here

# ── Web Push (VAPID) ─────────────────────────────────────────
# Generate once: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(JSON.stringify(k))"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:hello@askmynotes.in
